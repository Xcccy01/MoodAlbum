{
  "name": "family-care-app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "dev": "concurrently \"PORT=8787 node server/index.js\" \"vite\"",
    "build": "vite build",
    "start": "node server/index.js",
    "db:migrate": "node scripts/run-migrations.mjs",
    "db:check": "node scripts/postgres-production-check.mjs",
    "test:load": "node scripts/load-test.mjs",
    "test:ui": "playwright test",
    "android:sync": "npx cap sync android",
    "android:open": "npx cap open android",
    "android:apk": "npx cap sync android && cd android && gradlew.bat assembleDebug"
  },
  "dependencies": {
    "@capacitor/core": "^8.2.0",
    "express": "^4.21.2",
    "pg": "^8.14.1",
    "pg-mem": "^3.0.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.1"
  },
  "devDependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^8.2.0",
    "@playwright/test": "^1.54.2",
    "@vitejs/plugin-react": "^4.3.4",
    "autocannon": "^8.0.0",
    "concurrently": "^9.1.2",
    "vite": "^6.2.0"
  }
}
